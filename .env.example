# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# ======================
# IMPORTANT: Use different databases for development and production!
#
# Development (copy to .env):
# MONGODB_URI=mongodb+srv://YOUR_DB_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/keshless-tickets-dev
#
# Production (use .env.production):
# MONGODB_URI=mongodb+srv://YOUR_DB_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/keshless-tickets
#
# Local MongoDB (fallback):
MONGODB_URI=mongodb://localhost:27017/keshless-tickets-dev

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=7d

# Service-to-Service Authentication
# ==================================
# Shared secret key for main Keshless API to authenticate service requests
# IMPORTANT: Must match TICKETS_SERVICE_KEY in main Keshless API .env
# Generate a secure random key (e.g., openssl rand -hex 32)
SERVICE_KEY=kl_service_xxxxx_secure_key_here

# Keshless Integration (Payment Processor)
# ==========================================
# Keshless Tickets vendors use a shared Keshless vendor account for collecting payments
# API Key is used for server-to-server authentication (secure)
#
# Development:
KESHLESS_API_URL=http://localhost:3000/api
# Production:
# KESHLESS_API_URL=https://api.keshless.app/api
#
# Shared Keshless Vendor Account (all ticket payments go here)
KESHLESS_VENDOR_ID=your_keshless_vendor_id_here
#
# Integration API Key (generate via Keshless: POST /api/integrations)
# IMPORTANT: This is the API key, NOT a password. Keep it secret!
KESHLESS_API_KEY=kl_live_your_api_key_here_from_keshless_admin

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Sentry Error Tracking (Optional)
# Get your DSN from: https://sentry.io/settings/projects/
# Leave empty to disable Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=keshless-tickets-api@1.0.0
SERVER_NAME=keshless-tickets-api-dev

# SMS/Notification Configuration (Optional)
# Get your API key from: https://www.clickatell.com/
CLICKATELL_API_KEY=your-clickatell-api-key-here
CLICKATELL_BASE_URL=https://platform.clickatell.com/messages/http/send
SMS_ENABLED=false

# Notification Settings (which notifications to send by default)
SEND_PURCHASE_SMS=true
SEND_EVENT_REMINDER_SMS=true
SEND_CANCELLATION_SMS=true

# MTN MoMo Collections
MTN_MOMO_ENABLED=false
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_TARGET_ENV=sandbox
MTN_MOMO_CURRENCY=EUR
MTN_MOMO_CALLBACK_URL=

# Peach Payments (card via Payments API v2)
CARD_PAYMENTS_ENABLED=false
PEACH_BASE_URL=https://api-v2.peachpayments.com
PEACH_ENTITY_ID=
PEACH_USER_ID=
PEACH_PASSWORD=
PEACH_WEBHOOK_SECRET=
CARD_CURRENCY=ZAR
# shopperResultUrl sent to Peach — the SERVER return endpoint (accepts Peach's
# GET/POST 3DS return, finalises server-side, then 302s to the SPA page below).
CARD_RESULT_URL=https://api.carrottickets.com/api/public/purchase/peach-card/return
# SPA page the return endpoint redirects the buyer to for status display.
CARD_RESULT_PAGE_URL=https://carrottickets.com/payment-result
